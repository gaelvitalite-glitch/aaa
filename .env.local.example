# Copie ce fichier en .env.local puis renseigne tes clés.

# --- Copilote IA (Anthropic) ---
# Obtenir une clé : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (comptes utilisateurs + base de données) ---
# Laisse ces 2 lignes vides pour rester en mode local (localStorage, mono-appareil).
# Renseigne-les pour activer les comptes : Dashboard Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
